# Server
PORT=3001
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d
RATE_LIMIT_PER_MIN=60

# Database (SQLite for local dev)
DATABASE_URL="file:../prisma/dev.db"

# For PostgreSQL (production / Docker):
# DATABASE_URL="postgresql://vocentra:vocentra@localhost:5432/vocentra?schema=public"

# OpenAI (optional — mock responses used if not set)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Optional integrations
# WORDPRESS_URL=https://yoursite.com
# WORDPRESS_TOKEN=your_wordpress_token
# NOTION_TOKEN=your_notion_token
# NOTION_DATABASE_ID=your_database_id
# ASANA_TOKEN=your_asana_token
# ASANA_WORKSPACE_ID=your_workspace_id

NODE_ENV=development
